# =============================================================================
# Patio Lab — plantilla de variables de entorno
# -----------------------------------------------------------------------------
# COPIA este archivo a ".env" (sin el ".example") y rellena los valores.
# El archivo ".env" NUNCA se sube al repositorio (está en .gitignore): ahí van
# los secretos reales. Este ".env.example" sí se sube y sirve de documentación.
# =============================================================================

# Qué configuración cargar: development | testing | production
FLASK_CONFIG=development

# Clave secreta para firmar las sesiones y los tokens CSRF.
# En desarrollo vale cualquier cosa; en producción genera una larga y aleatoria,
# por ejemplo con:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-en-produccion

# URL de la base de datos.
# - En desarrollo lo dejamos vacío y se usa un SQLite local (ver config.py).
# - En producción aquí irá algo como:
#     postgresql://usuario:password@host:5432/patiolab
DATABASE_URL=
